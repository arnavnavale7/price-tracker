# ─── Price Tracker API Keys ───────────────────────────────────────────────────

# OPTION A: RapidAPI (RECOMMENDED — easiest, FREE 100 req/month)
#   1. Sign up at https://rapidapi.com
#   2. Subscribe to "Real-Time Amazon Data" API (free plan):
#      https://rapidapi.com/letscrape-6bRBa3QguO5/api/real-time-amazon-data
#   3. Paste your RapidAPI key below:
RAPIDAPI_KEY=

# OPTION B: Playwright (no key needed, just install):
#   pip install playwright && playwright install chromium

# OPTION C: ScraperAPI (optional fallback)
SCRAPER_API_KEY=e47b9fe3839f6c67acf8ca4c02f9c821

# ─── Email Notifications (for Price Watches) ─────────────────────────────────
# Configure SMTP settings to receive price drop notifications.
# If not configured, notifications will be skipped with a log message.
# Recommended: use Gmail App Password (https://support.google.com/accounts/answer/185833)

SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=pricetracker.notify@gmail.com
SMTP_PASSWORD=lmhztxhovgikrwjc

# ─── Watch Settings ───────────────────────────────────────────────────────────
# How often (in hours) to check active price watches. Default: 24 (daily)
WATCH_CHECK_INTERVAL_HOURS=24