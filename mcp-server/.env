# ─── Stitch MCP Server Configuration ──────────────────────────────────────────

# Price Tracker API endpoint (where the backend is running)
# Default: http://localhost:8000
PRICE_TRACKER_API=http://localhost:8000

# MCP Server port
# Default: 3001
MCP_PORT=3001

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Enable detailed request/response logging
VERBOSE_LOGGING=false

# ─── Optional: Cloud Integration ──────────────────────────────────────────────

# Google Cloud Project ID (for BigQuery export)
# GCP_PROJECT_ID=your-project-id

# Google Cloud credentials (path to service account JSON)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# BigQuery dataset for archiving price history
# BIGQUERY_DATASET=price_tracker

# ─── Optional: AWS Integration ────────────────────────────────────────────────

# AWS region for data storage
# AWS_REGION=us-east-1

# S3 bucket for storing CSV exports
# S3_BUCKET=price-tracker-data

# DynamoDB table for watch metadata
# DYNAMODB_TABLE=price_watches
